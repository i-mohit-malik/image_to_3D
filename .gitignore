# Ignore credentials
.env

# Output models and caches
# Keep the folder in git even if it's empty by tracking a placeholder file.
output/*
!output/.gitkeep

# Input images (user-provided). Keep an empty folder for guidance.
input_images/*
!input_images/.gitkeep

# Python bytecode
__pycache__/
*.pyc

# Virtual environment
.venv/
/.venv
